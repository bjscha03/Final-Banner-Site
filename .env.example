# ============================================================================
# Print Pipeline (Beta) - Feature Flag
# ============================================================================

# Enable/disable the print pipeline feature
# When false: Site behaves exactly as before (no new buttons, no new endpoints)
# When true: Enables Print-Grade PDF, Quality Check, and AI print derivatives
ENABLE_PRINT_PIPELINE=false

# Print Pipeline Configuration
PRINT_DEFAULT_DPI=300
PRINT_BLEED_IN=0.25
PRINT_COLOR_SPACE=srgb
PRINT_FORMAT=jpeg

# ============================================================================
# Vite Environment Variables (Client-Side)
# ============================================================================

# These must be prefixed with VITE_ to be accessible in the browser
VITE_ENABLE_PRINT_PIPELINE=false
VITE_PRINT_DEFAULT_DPI=300
VITE_PRINT_BLEED_IN=0.25
VITE_PRINT_FORMAT=jpeg

# AI Upscale Hook (scaffolding – requires Cloudinary AI Super Resolution add-on)
# When true, the upscaleForPrint utility applies Cloudinary AI upscale before export
ENABLE_UPSCALE=false
VITE_ENABLE_UPSCALE=false

# ============================================================================
# Cloudinary Configuration (Required for print derivatives)
# ============================================================================

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Client-side Cloudinary (for URL generation)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ============================================================================
# Canva Integration
# ============================================================================

# Canva app preview base URL (from Canva app configuration)
CANVA_PREVIEW_BASE=https://your-canva-app-preview-url.com

# Canva client secret for webhook signature verification
CANVA_CLIENT_SECRET=your_canva_client_secret

# Cloudinary configuration for Canva uploads
CLOUDINARY_CLOUD_NAME=dtrx1l20u
CLOUDINARY_UNSIGNED_PRESET=canva_upload

# ============================================================================
# PostHog Analytics (for promo tracking and user analytics)
# ============================================================================

# PostHog API key (get from PostHog project settings)
VITE_POSTHOG_API_KEY=your_posthog_api_key

# PostHog host (default: https://app.posthog.com, or use self-hosted URL)
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# ============================================================================
# Email Provider (Resend) - For discount code emails
# ============================================================================

# Resend API key for sending transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# From email address (must be verified in Resend)
EMAIL_FROM=orders@bannersonthefly.com

# ============================================================================
# Google Ads Conversion Tracking
# ============================================================================

# Google Ads conversion ID (e.g. AW-1234567890). Required to fire the Google Ads
# purchase conversion event from PaymentSuccess. Leave blank to disable.
VITE_GOOGLE_ADS_CONVERSION_ID=

# Google Ads purchase conversion label (the value after the slash in send_to).
# Leave blank to disable. Both ID and label must be set for conversions to fire.
VITE_GOOGLE_ADS_PURCHASE_LABEL=

# ============================================================================
# Google Vertex AI (Imagen) — "Create with AI" feature
# ============================================================================
# Required for the /.netlify/functions/generate-design endpoint.
# Server-side only — do NOT expose to the browser.

# GCP project that has the Vertex AI API enabled.
GOOGLE_CLOUD_PROJECT_ID=

# Service-account credentials. Provide ONE of:
#   - GOOGLE_APPLICATION_CREDENTIALS_JSON: the raw JSON content of a service
#     account key, OR a base64-encoded version of that JSON. Recommended on
#     Netlify since the filesystem is ephemeral.
#   - GOOGLE_APPLICATION_CREDENTIALS: filesystem path to a service-account
#     key JSON file. Useful for local development.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=

# Vertex AI region. Defaults to us-central1 if unset.
VERTEX_AI_LOCATION=us-central1

# Imagen model name. Defaults to imagegeneration@006 if unset.
VERTEX_AI_IMAGEN_MODEL=imagegeneration@006
